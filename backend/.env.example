# ===== 后端环境变量示例 =====
# 复制为 .env 并按需填写：copy .env.example .env

# 调试模式（true 时输出彩色日志 + SQL echo）
DEBUG=false

# 数据库（本地默认指向仓库 data/stock.db；Docker 内由 compose 覆盖）
# DATABASE_URL=sqlite:///../data/stock.db

# 基准货币：JPY / USD / CNY
BASE_CURRENCY=JPY

# Anthropic API Key（AI 功能需要；缺失时 AI 模块优雅降级）
ANTHROPIC_API_KEY=

# AI 月度预算硬上限（JPY）
AI_MONTHLY_BUDGET_JPY=2000

# 展示时区
DISPLAY_TIMEZONE=Asia/Tokyo
