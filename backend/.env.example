# ===== 后端环境变量示例 =====
# 复制为 .env 并按需填写：copy .env.example .env

# 调试模式（true 时输出彩色日志 + SQL echo）
DEBUG=false

# 数据库（本地默认指向仓库 data/stock.db；Docker 内由 compose 覆盖）
# DATABASE_URL=sqlite:///../data/stock.db

# 基准货币：JPY / USD / CNY
BASE_CURRENCY=JPY

# Anthropic API Key（AI 功能需要；缺失时 AI 模块优雅降级）
# 用 DeepSeek 时这里填 DeepSeek 的 API Key
ANTHROPIC_API_KEY=

# AI 服务端点（用 DeepSeek 的 Anthropic 兼容端点时填下面这行）
# AI_BASE_URL=https://api.deepseek.com/anthropic
AI_BASE_URL=

# 覆盖所有任务的模型名（用 DeepSeek 时填 deepseek-chat；为空则用内置 Claude 分级表）
# AI_MODEL=deepseek-chat
AI_MODEL=

# AI 月度预算硬上限（JPY）
AI_MONTHLY_BUDGET_JPY=2000

# 展示时区
DISPLAY_TIMEZONE=Asia/Tokyo

# 启用后台行情调度（APScheduler，按 JST 时间表）
ENABLE_SCHEDULER=false

# 备份加密口令（设置后 scripts/backup.py 输出 .gz.enc 加密文件）
BACKUP_PASSWORD=
