{
  "name": "hindsight-desktop",
  "version": "0.1.6",
  "private": true,
  "description": "Hindsight 桌面客户端（Windows）",
  "author": "Hindsight",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/prepare-resources.mjs && electron-builder --win --x64",
    "prepare-resources": "node scripts/prepare-resources.mjs"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.tradeai.desktop",
    "productName": "Hindsight",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://154.36.185.85:8090/updates/"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend"
      },
      {
        "from": "resources/frontend",
        "to": "frontend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hindsight"
    }
  }
}
